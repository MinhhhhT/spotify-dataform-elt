config {
  type: "assertion",
  name: "assert_stg_track_quarantine_error_rate",
  tags: ["staging", "assertion"],
}

WITH
  validation_data AS (
    SELECT
      *
    FROM
      ${ref("stg_track_quarantine")}
  )
SELECT
  SUM(
    CASE
      WHEN validation_status = "valid" THEN 1
      ELSE 0
    END
  ) / COUNT(*) AS success_rate
FROM
  validation_data
HAVING
  success_rate <= 0.1